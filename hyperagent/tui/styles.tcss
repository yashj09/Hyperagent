/* HyperAgent TUI Stylesheet — Dark trading terminal theme */

Screen {
    background: #0d1117;
    color: #c9d1d9;
}

Header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

Footer {
    background: #161b22;
    color: #8b949e;
}

/* ---------- Tab styling ---------- */

TabbedContent {
    background: #0d1117;
}

TabPane {
    background: #0d1117;
    padding: 0;
}

ContentSwitcher {
    background: #0d1117;
}

Tabs {
    background: #161b22;
    color: #8b949e;
}

Tab {
    background: #161b22;
    color: #8b949e;
    padding: 0 2;
}

Tab.-active {
    background: #0d1117;
    color: #58a6ff;
    text-style: bold;
}

/* ---------- Panel IDs ---------- */

#header-panel {
    background: #161b22;
    color: #58a6ff;
    height: 3;
    padding: 0 1;
    border-bottom: solid #30363d;
}

#market-panel {
    background: #161b22;
    border: solid #30363d;
    height: 3;
    padding: 0 1;
    margin: 0 0 1 0;
}

#heatmap-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: 100%;
}

#alerts-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: auto;
    max-height: 12;
}

#positions-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: 100%;
}

#log-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: 100%;
}

#ai-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: auto;
    max-height: 10;
}

/* ---------- Score classes ---------- */

.high-score {
    color: #f85149;
    text-style: bold;
}

.medium-score {
    color: #d29922;
    text-style: bold;
}

.low-score {
    color: #8b949e;
}

/* ---------- Stop-loss flash ---------- */

.stop-loss-flash {
    background: #5c1010;
    color: #ff6b6b;
    text-style: bold;
}

/* ---------- Dashboard layout ---------- */

#dashboard-container {
    layout: grid;
    grid-size: 2 3;
    grid-rows: 3 1fr 1fr;
    grid-columns: 1fr 1fr;
    grid-gutter: 1;
    padding: 0 1;
    height: 100%;
}

#market-ticker-row {
    column-span: 2;
    height: 3;
}

/* ---------- Right column sub-layout ---------- */

#right-top-container {
    layout: vertical;
    height: 100%;
}

/* ---------- Strategy Config Screen ---------- */

#strategy-container {
    layout: vertical;
    padding: 1 2;
    height: 100%;
}

#strategy-header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
    padding: 1;
    height: 3;
    margin-bottom: 1;
}

#strategy-controls {
    layout: horizontal;
    height: 5;
    margin-bottom: 1;
}

#strategy-select-box {
    width: 40;
    margin-right: 2;
}

#ai-toggle-box {
    width: 25;
    margin-right: 2;
}

#strategy-button {
    margin-top: 1;
}

#strategy-start-btn {
    background: #238636;
    color: #ffffff;
    text-style: bold;
    min-width: 16;
}

#strategy-start-btn:hover {
    background: #2ea043;
}

#strategy-stop-btn {
    background: #da3633;
    color: #ffffff;
    text-style: bold;
    min-width: 16;
}

#strategy-description {
    background: #161b22;
    border: solid #30363d;
    padding: 1;
    height: auto;
    max-height: 8;
    margin-bottom: 1;
}

#strategy-params-table {
    height: 1fr;
    border: solid #30363d;
}

/* ---------- Journal Screen ---------- */

#journal-container {
    layout: vertical;
    padding: 1 2;
    height: 100%;
}

#journal-header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
    padding: 1;
    height: 3;
    margin-bottom: 1;
}

#journal-table {
    height: 1fr;
    border: solid #30363d;
}

#journal-summary {
    background: #161b22;
    border: solid #30363d;
    padding: 1;
    height: 3;
    margin-top: 1;
}

/* ---------- Positive / Negative colors ---------- */

.positive {
    color: #3fb950;
}

.negative {
    color: #f85149;
}

.neutral {
    color: #8b949e;
}

/* ---------- DataTable styling ---------- */

DataTable {
    background: #0d1117;
    color: #c9d1d9;
}

DataTable > .datatable--header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #1f2937;
    color: #c9d1d9;
}

/* ---------- Select / Switch / Button ---------- */

Select {
    background: #161b22;
    border: solid #30363d;
}

Switch {
    background: #30363d;
}

Switch.-on {
    background: #238636;
}

Button {
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
}

Button:hover {
    background: #30363d;
}

Label {
    color: #8b949e;
    padding: 0 1;
}
