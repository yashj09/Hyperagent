/* HyperAgent TUI Stylesheet */

Screen {
    background: #0d1117;
    color: #c9d1d9;
}

Header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

Footer {
    background: #161b22;
    color: #8b949e;
}

TabbedContent {
    background: #0d1117;
    height: 1fr;
}

ContentSwitcher {
    background: #0d1117;
    height: 1fr;
}

TabPane {
    background: #0d1117;
    padding: 0;
    height: 1fr;
}

Tabs {
    background: #161b22;
    color: #8b949e;
}

Tab {
    background: #161b22;
    color: #8b949e;
    padding: 0 2;
}

Tab.-active {
    background: #0d1117;
    color: #58a6ff;
    text-style: bold;
}

/* ===== Dashboard Layout ===== */

#dashboard-container {
    height: 100%;
    padding: 0 1;
}

#market-panel {
    background: #161b22;
    border: solid #30363d;
    height: 3;
    padding: 0 1;
    margin-bottom: 1;
    dock: top;
}

#dashboard-row2 {
    height: 50%;
    margin-bottom: 1;
}

#dashboard-row3 {
    height: 50%;
}

#heatmap-scroll {
    width: 1fr;
    height: 100%;
    margin-right: 1;
    border: solid #30363d;
    background: #0d1117;
}

#heatmap-panel {
    padding: 1;
}

#right-top-container {
    width: 1fr;
    height: 100%;
}

#alerts-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: 1fr;
    margin-bottom: 1;
    overflow-y: auto;
}

#ai-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    height: auto;
    max-height: 12;
}

#positions-scroll {
    width: 1fr;
    height: 100%;
    margin-right: 1;
    border: solid #30363d;
    background: #0d1117;
}

#positions-panel {
    padding: 1;
}

#log-panel {
    background: #0d1117;
    border: solid #30363d;
    padding: 1;
    width: 1fr;
    height: 100%;
    overflow-y: auto;
}

/* ===== Score Classes ===== */

.high-score {
    color: #f85149;
    text-style: bold;
}

.medium-score {
    color: #d29922;
    text-style: bold;
}

.low-score {
    color: #8b949e;
}

/* ===== Stop-Loss Flash ===== */

.stop-loss-flash {
    background: #5c1010;
    color: #ff6b6b;
    text-style: bold;
}

/* ===== Strategy Config Screen ===== */

#strategy-container {
    padding: 1 2;
    height: 100%;
}

#strategy-header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
    padding: 1;
    height: 3;
    margin-bottom: 1;
}

#strategy-controls {
    height: 5;
    margin-bottom: 1;
}

#strategy-select-box {
    width: 40;
    margin-right: 2;
}

#ai-toggle-box {
    width: 25;
    margin-right: 2;
}

#strategy-button {
    margin-top: 1;
}

#strategy-start-btn {
    background: #238636;
    color: #ffffff;
    text-style: bold;
    min-width: 16;
}

#strategy-start-btn:hover {
    background: #2ea043;
}

#strategy-stop-btn {
    background: #da3633;
    color: #ffffff;
    text-style: bold;
    min-width: 16;
}

#strategy-description {
    background: #161b22;
    border: solid #30363d;
    padding: 1;
    height: auto;
    max-height: 8;
    margin-bottom: 1;
}

#strategy-params-hint {
    color: #8b949e;
    padding: 0 1;
    height: 1;
    margin-bottom: 1;
}

#enabled-assets-label {
    color: #58a6ff;
    text-style: bold;
    padding: 0 1;
    margin-top: 1;
}

#enabled-assets-row {
    height: 5;
    background: #0d1117;
    border: solid #30363d;
    margin-bottom: 1;
    padding: 0 1;
}

.asset-toggle-cell {
    width: auto;
    height: auto;
    margin-right: 2;
    align: center middle;
}

.asset-toggle-label {
    color: #c9d1d9;
    text-align: center;
    width: 6;
}

.asset-switch {
    width: 6;
}

/* ===== Analytics Tab ===== */

#analytics-container {
    height: 100%;
    padding: 0 1;
}

#analytics-header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
    padding: 1;
    height: 3;
    margin-bottom: 1;
}

#analytics-equity-plot {
    height: 16;
    border: solid #30363d;
    margin-bottom: 1;
}

#analytics-bars-row {
    height: 14;
    margin-bottom: 1;
}

#analytics-strategy-plot,
#analytics-coin-plot {
    width: 1fr;
    height: 100%;
    border: solid #30363d;
}

#analytics-strategy-plot {
    margin-right: 1;
}

#analytics-tables-scroll {
    height: 1fr;
    border: solid #30363d;
    background: #161b22;
}

.analytics-subheader {
    color: #58a6ff;
    text-style: bold;
    padding: 1 1 0 1;
    background: #161b22;
}

#analytics-strategy-table,
#analytics-coin-table,
#analytics-side-table {
    height: auto;
    margin-bottom: 1;
}

#strategy-params-table {
    height: 1fr;
    border: solid #30363d;
}

#strategy-params-table > .datatable--cursor {
    background: #1f6feb;
    color: #ffffff;
}

/* ===== Journal Screen ===== */

#journal-container {
    padding: 1 2;
    height: 100%;
}

#journal-header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
    padding: 1;
    height: 3;
    margin-bottom: 1;
}

#journal-table {
    height: 1fr;
    border: solid #30363d;
}

#journal-summary {
    background: #161b22;
    border: solid #30363d;
    padding: 1;
    height: 3;
    margin-top: 1;
}

/* ===== Colors ===== */

.positive { color: #3fb950; }
.negative { color: #f85149; }
.neutral  { color: #8b949e; }

/* ===== DataTable ===== */

DataTable {
    background: #0d1117;
    color: #c9d1d9;
}

DataTable > .datatable--header {
    background: #161b22;
    color: #58a6ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #1f2937;
    color: #c9d1d9;
}

/* ===== Widgets ===== */

Select {
    background: #161b22;
    border: solid #30363d;
}

Switch {
    background: #30363d;
}

Switch.-on {
    background: #238636;
}

Button {
    background: #21262d;
    color: #c9d1d9;
    border: solid #30363d;
}

Button:hover {
    background: #30363d;
}

Label {
    color: #8b949e;
    padding: 0 1;
}
