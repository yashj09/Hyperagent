# HyperAgent config example
#
# ⚠  TESTNET AGENT WALLET ONLY.
# ⚠  Never paste your main wallet's private key here.
#
# Generate an agent wallet at:
#   https://app.hyperliquid-testnet.xyz/API
#
# Agent wallets can place trades for your main account, but they
# CANNOT withdraw funds. Revocable any time from the same page.
#
# Easier path: run `hyperagent setup` and the wizard writes this file
# for you at ~/.config/hyperagent/.env.

HL_NETWORK=testnet
HL_MAIN_ADDRESS=0x_your_main_wallet_public_address
HL_AGENT_PRIVATE_KEY=0x_agent_wallet_private_key_from_hyperliquid

# Optional: AWS Bedrock creds for Claude Haiku trade explanations.
# Leave blank to run without AI.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Optional: HypeDexer API key. Required only for the Liquidation
# Cascade v2 strategy; the other five strategies work without it.
HYPEDEXER_API_KEY=
